# ============== AI-Бухгалтер Landing — переменные окружения ==============
# Этот файл коммитится в git как пример. Реальные значения — в Vercel Dashboard
# (Project Settings → Environment Variables) или через `vercel env add`.

# ============== Prodamus (платежи) ==============
# Получить в кабинете https://prodamus.ru → Настройки → API
PRODAMUS_SHOPNAME=         # имя твоего магазина в Prodamus (например: aibuhgalter)
PRODAMUS_API_TOKEN=        # API token для серверных запросов
PRODAMUS_SECRET_KEY=       # Secret для проверки HMAC подписи webhook
PRODAMUS_WEBHOOK_SECRET=   # дополнительный shared-secret который мы сами генерим

# Маппинг тариф → product_id Prodamus
PRODAMUS_PRODUCT_PRO_IP=     # ID продукта "PRO ИП 290 ₽/мес"
PRODAMUS_PRODUCT_PRO_BUH=    # ID продукта "PRO Бухгалтерия 990 ₽/мес"
PRODAMUS_PRODUCT_MAX=        # ID продукта "MAX 1990 ₽/мес"

# ============== Telegram Bot (для уведомлений админу) ==============
# Получить у @BotFather, для бота @AI_Buxgalter_USN_bot
TG_BOT_TOKEN=                # токен бота для отправки уведомлений
TG_ADMIN_CHAT_ID=            # твой chat_id (узнать через @userinfobot)

# ============== Database (общая с ботом) ==============
# Railway PostgreSQL — тот же что у бота, для синхронизации подписок
DATABASE_URL=                # postgresql://user:pass@host:port/dbname

# ============== Email (Resend для transactional + admin magic-link) ==============
# Бесплатный тир на resend.com (100 писем/день)
RESEND_API_KEY=              # re_xxxxxxxxxxxxx
EMAIL_FROM=noreply@aibuhgalter.com
EMAIL_ADMIN=alikazakov9@gmail.com

# ============== Admin Panel ==============
# Список email которым разрешён вход в /admin (через запятую, без пробелов)
ADMIN_EMAILS=alikazakov9@gmail.com
# JWT secret для сессий админки (рандомные 64+ байт, например через `openssl rand -hex 64`)
ADMIN_JWT_SECRET=

# ============== Vercel Analytics (опционально, для админки если хотим показывать данные оттуда) ==============
# Personal token: https://vercel.com/account/tokens
VERCEL_API_TOKEN=
VERCEL_TEAM_ID=team_dEE5Pz62y1Dcnl5lNfKDbBuo
VERCEL_PROJECT_ID=prj_DyajbMcrqwCkqke8A86c2cwAs0Ng

# ============== Feature flags ==============
NEXT_PUBLIC_FORMSUBMIT_ENABLED=true
NEXT_PUBLIC_PAYMENTS_ENABLED=false   # включим после интеграции Prodamus
NEXT_PUBLIC_ADMIN_PANEL_ENABLED=false  # включим когда админка готова
